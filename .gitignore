# Next.js build and cache outputs
/.next/
/out/

# Production builds
/build

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing coverage
/coverage

# Environment files (sensitive configurations)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# EXCEPTION: Allow environment examples to be committed so other developers know required keys
!.env.example
!.env.local.example

# Local App Databases / Scraper outputs (avoid personal job lists leakage & merge conflicts)
/data/applications.json

# AI Agents & Local Workspace Skills
.agent/
.agents/

# System / OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and Text Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# TypeScript / Compilations
*.tsbuildinfo
next-env.d.ts

# Debug and log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
